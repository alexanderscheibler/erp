{
  "name": "erp",
  "version": "1.0.0",
  "main": "index.js",
  "description": "E2E suite for ERP Odoo 19",
  "private": true,
  "type": "module",
  "repository": "git@github.com:alexanderscheibler/erp.git",
  "author": "Alexander Scheibler <60936422+alexanderscheibler@users.noreply.github.com>",
  "license": "MIT",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "infra:up": "docker compose up -d && ./scripts/wait-for-odoo.sh",
    "infra:down": "docker compose down -v --remove-orphans",
    "e2e": "./scripts/run_e2e.sh",
    "lint": "eslint \"**/*.{ts,tsx}\" --ignore-pattern node_modules --ignore-pattern dist --ignore-pattern build",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
